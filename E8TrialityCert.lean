/-! ## Section A: even unimodular Gram certificates for the two E8 copies -/
theorem GE8_even : evenDiag GE8 = true := by native_decide
theorem GE8_unimodular : mul GE8 GE8i = idm 8 ∧ mul GE8i GE8 = idm 8 := by native_decide
theorem GL_even : evenDiag GL = true := by native_decide
theorem GL_unimodular : mul GL GLi = idm 8 ∧ mul GLi GL = idm 8 := by native_decide

/-! ## Section B: two A9 copies inside W(E8); split vs nonsplit -/
theorem vector_gens_isometries :
    Vgens.all (fun A => mul (mul A GE8) (tr A) == GE8) = true := by native_decide
theorem spin_gens_isometries :
    Sgens.all (fun A => mul (mul A GL) (tr A) == GL) = true := by native_decide
theorem split_witness : mul (mul V1 V2) (mul V1 V2) = idm 8 := by native_decide
theorem nonsplit_witness : mul (mul S1 S2) (mul S1 S2) = negm (idm 8) := by native_decide

/-! ## Section C: Clifford provenance of the spin copy -/
theorem clifford_relations :
    ((List.range 8).all (fun i => (List.range 8).all (fun j =>
      let s := mul (Gammas.get! i) (Gammas.get! j)
      let t := mul (Gammas.get! j) (Gammas.get! i)
      (List.range 16).all (fun a => (List.range 16).all (fun b =>
        ((s.get! a).get! b + (t.get! a).get! b) ==
          (if i = j ∧ a = b then (2:Int) else 0)))))) = true := by native_decide
theorem clifford_nonsplit_lift :
    mul (mul Rh1 Rh3) (mul Rh1 Rh3) = smul (-64) (idm 16) := by native_decide

/-! ## Section D: the isometry Q ≅ A2 ⊗ E8 -/
theorem Q_even : evenDiag GQ = true := by native_decide
theorem isometry_Q_A2E8 : mul (mul Tiso GQ) (tr Tiso) = GA := by native_decide
theorem Tiso_unimodular : mul Tiso TisoInv = idm 16 ∧ mul TisoInv Tiso = idm 16 := by native_decide

/-! ## Section E: sqrt2*E8 blocks, R = sqrt3*E8, and the Leech Gram -/
theorem sqrt2E8_certificate :
    evenDiag U2 = true ∧ mul U2 U2i = idm 8 ∧ mul U2i U2 = idm 8 := by native_decide
theorem sqrt3E8_certificate :
    evenDiag U3 = true ∧ mul U3 U3i = idm 8 ∧ mul U3i U3 = idm 8 := by native_decide
theorem leech_even_unimodular :
    evenDiag G24 = true ∧ mul G24 G24i = idm 24 ∧ mul G24i G24 = idm 24 := by native_decide

/-! ## Section F: binary Turyn glue — 2^12 words, cyclic shift invariance -/
def glueWords : List Nat :=
  (List.range 4096).map (fun m =>
    (List.range 12).foldl (fun a k => if m.testBit k then a ^^^ (glueGens.get! k) else a) 0)
def shift3 (n : Nat) : Nat := (n >>> 16) ||| ((n &&& 0xFFFF) <<< 8)
theorem glue_distinct :
    ((glueWords.foldl (fun (p : List Nat × Bool) w =>
        (w :: p.1, p.2 && !(p.1.contains w))) ([], true)).2) = true := by native_decide
theorem glue_shift_invariant :
    (glueWords.all (fun w => glueWords.contains (shift3 w))) = true := by native_decide

/-! ## Section G: orbit fingerprints on E8/2E8 — triality fusion -/
def actRow (row v : Nat) : Nat :=
  ((List.range 8).foldl (fun a j => if row.testBit j && v.testBit j then a+1 else a) 0) % 2
def act (g : List Nat) (v : Nat) : Nat :=
  (List.range 8).foldl (fun acc i => if actRow (g.get! i) v == 1 then acc ||| (1 <<< i) else acc) 0
def rowmasks (A : Mat) : List Nat :=
  (List.range 8).map (fun i => (List.range 8).foldl
    (fun m j => if ((A.get! i).get! j) % 2 == 1 then m ||| (1 <<< j) else m) 0)
def grow (gens : List (List Nat)) : List Nat → Nat → List Nat
  | acc, 0 => acc
  | acc, fuel+1 =>
      let nw := ((acc.map (fun v => gens.map (fun g => act g v))).flatten.foldl
        (fun l v => if acc.contains v || l.contains v then l else v :: l) [])
      if nw.isEmpty then acc else grow gens (acc ++ nw) fuel
def orbitOf (gens : List (List Nat)) (v : Nat) : List Nat := grow gens [v] 300
def ins (x : Nat) : List Nat → List Nat
  | [] => [x]
  | y :: ys => if x ≤ y then x :: y :: ys else y :: ins x ys
def orbitSizes (gens : List (List Nat)) : List Nat :=
  (((List.range 256).drop 1).foldl (fun (st : List Nat × List Nat) v =>
    if st.1.contains v then st
    else let ob := orbitOf gens v; (st.1 ++ ob, ins ob.length st.2)) ([], [])).2
theorem vector_orbits :
    orbitSizes (Vgens.map rowmasks) = [9, 36, 84, 126] := by native_decide
theorem spin_orbits :
    orbitSizes (Sgens.map rowmasks) = [120, 135] := by native_decide
